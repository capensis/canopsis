# Canopsis CSS/JS files have unique hashes in each official build.
# Add a bit of cache to some other static elements as well, but don't
# cache other resources.
map $sent_http_content_type $expires_time {
	default			-1;
	text/css		1d;
	application/javascript	1d;
	font/woff2		1d;
	image/gif		1h;
	image/png		1h;
	image/x-icon		1h;
}

server {
	listen 8080;
	root /opt/canopsis/var/www/src/canopsis-next/dist;

	# Work around issue canopsis#1858
	client_max_body_size 7m;
	large_client_header_buffers 4 20k;

	gzip on;
	gzip_comp_level 4;
	gzip_min_length 1100;
	gzip_proxied any;
	gzip_vary on;
	gzip_types
	    text/plain text/css
	    application/javascript application/json application/xml
	    image/bmp image/svg+xml image/vnd.microsoft.icon image/x-icon;

	expires $expires_time;

	location = / {
		return 303 /en/static/canopsis-next/dist/index.html;
	}

	# Serve static files directly through Nginx by default
	location /en/static/canopsis-next/dist/ {
		rewrite ^/en/static/canopsis-next/dist(/.+?)$ $1 break;
	}

	# Everything else goes to canopsis-api, because it's very likely an API call
	location / {
		if ($request_method = 'OPTIONS') {
			add_header 'Access-Control-Allow-Origin' "$http_origin";
			add_header 'Access-Control-Allow-Credentials' 'true';
			add_header 'Access-Control-Allow-Headers' 'Authorization,Cache-Control,Content-Type';
			add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS';
			add_header 'Access-Control-Max-Age' '31536000';
			add_header 'Content-Type' 'text/plain; charset=UTF-8';
			add_header 'Content-Length' 0;

			return 204;
		}

		if ($request_method = 'POST') {
			add_header 'Access-Control-Allow-Origin' "$http_origin";
			add_header 'Access-Control-Allow-Credentials' 'true';
			add_header 'Access-Control-Allow-Headers' 'Authorization,Cache-Control,Content-Type';
		}

		if ($request_method = 'GET') {
			add_header 'Access-Control-Allow-Origin' "$http_origin";
			add_header 'Access-Control-Allow-Credentials' 'true';
			add_header 'Access-Control-Allow-Headers' 'Authorization,Cache-Control,Content-Type';
		}

		proxy_pass {{ TARGET }};
		proxy_set_header X-Forwarded-Host $host;
		proxy_set_header X-Forwarded-Server $host;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	}
}
