server_tokens off;

# Canopsis CSS/JS files have unique hashes in each official build.
# Add a bit of cache to some other static elements as well, but don't
# cache other resources.
map $sent_http_content_type $expires_time {
	default				-1;
	text/css			1d;
	application/javascript		1d;
	application/vnd.ms-fontobject	1d;
	font/ttf			1d;
	font/woff			1d;
	font/woff2			1d;
	image/gif			1h;
	image/png			1h;
	image/x-icon			1h;
}

server {
	listen 8080;

	# Work around issue canopsis#1858
	client_max_body_size 7m;
	large_client_header_buffers 4 20k;

	gzip on;
	gzip_comp_level 4;
	gzip_min_length 1100;
	gzip_proxied any;
	gzip_vary on;
	gzip_types
	    text/plain text/css
	    application/javascript application/json application/xml
	    image/bmp image/svg+xml image/vnd.microsoft.icon image/x-icon;

	expires $expires_time;

	# This old URL shouldn't be used anymore
	location = /en/static/canopsis-next/dist/index.html {
		return 301 /;
	}

	# Redirect to /canopsis, because some APIv1 calls didn't use the /api/
	# namespace, so there could be a conflict between them and the UI.
	location = / {
		include /etc/nginx/cors.inc;
		return 303 /canopsis;
	}

	# Serve static files directly through Nginx by default
	location /canopsis {
		include /etc/nginx/cors.inc;
		alias /opt/canopsis/var/www/src/canopsis-next/dist/;
	}

	# Everything else goes to canopsis-api, because it's very likely an API call
	location / {
		include /etc/nginx/cors.inc;

		proxy_pass {{ CPS_API_URL }};
		proxy_set_header X-Forwarded-Host $host;
		proxy_set_header X-Forwarded-Server $host;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
	}
}
